# =============================================================================
# Required for app API calls
# =============================================================================

# Backend API base URL (no trailing slash). Used by the fetch client for auth and data.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# =============================================================================
# Optional — public site / SEO / marketing (safe to expose; NEXT_PUBLIC_*)
# Leave blank to use code defaults described below.
# =============================================================================

# Canonical site origin (https, no trailing slash). metadataBase, Open Graph / Twitter
# absolute URLs, sitemap.xml, robots host, JSON-LD @id URLs. Blank → default in site-config.
NEXT_PUBLIC_SITE_URL=

# Public contact email: /contact mailto + Organization contactPoint in homepage JSON-LD.
# Blank → it@henchsolutions.com (see src/lib/site-config.ts).
NEXT_PUBLIC_CONTACT_EMAIL=

# Google Search Console HTML tag verification (content value only). Blank → no meta tag.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
